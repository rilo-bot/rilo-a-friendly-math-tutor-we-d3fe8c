# Server
PORT=3001

# Provided by the preview runtime — NOT user secrets, so they stay commented (never "asked" for):
#   MONGO_URI   — connection string for the per-preview Mongo sidecar
#   CLIENT_DIST — path to the built client the server serves (single-origin)

# RILO-managed OpenAI credentials — injected by the platform at runtime; never set manually.
# The local fallback solver is used automatically when these are absent.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
